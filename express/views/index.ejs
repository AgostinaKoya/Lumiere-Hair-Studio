<!DOCTYPE html>
<html>
<head>
  <title>Auth</title>

  <style>

    body{
      font-family: Arial;
      display:flex;
      justify-content:center;
      gap:50px;
      margin-top:100px;
    }

    .card{
      border:1px solid #ddd;
      padding:20px;
      border-radius:10px;
      width:260px;
    }

    input{
      width:100%;
      margin-bottom:10px;
      padding:8px;
    }

    button{
      width:100%;
      padding:8px;
      cursor:pointer;
    }

    .message{
      display:block;
      margin-top:10px;
      height:18px;
      font-size:14px;
    }

    .success{
      color:green;
    }

    .error{
      color:red;
    }

  </style>

</head>

<body>

<% if (!user) { %>

<!-- LOGIN -->

<div class="card">

<h2>Login</h2>

<form id="loginForm">

<input type="email" name="email" placeholder="Email" required>
<input type="password" name="password" placeholder="Password" required>

<button type="submit">Login</button>

</form>

<span id="loginMessage" class="message"></span>

</div>


<!-- REGISTER -->

<div class="card">

<h2>Register</h2>

<form id="registerForm">

<input type="email" name="email" placeholder="Email" required>
<input type="password" name="password" placeholder="Password" required>

<button type="submit">Register</button>

</form>

<span id="registerMessage" class="message"></span>

</div>

<% } else { %>

<!-- USUARIO LOGUEADO -->

<div class="card">

<h2>Bienvenido</h2>

<p><%= user.email %></p>

<a href="/protected">
<button>Ir a protected</button>
</a>

<form action="/logout" method="POST" style="margin-top:10px">

<button type="submit">
Cerrar sesión
</button>

</form>

</div>

<% } %>


<script>

function showMessage(id, message, type){

const el = document.getElementById(id)

if(!el) return

el.textContent = message
el.className = `message ${type}`

setTimeout(()=>{
el.textContent=''
el.className='message'
},2000)

}


// LOGIN

const loginForm = document.getElementById('loginForm')

if(loginForm){

loginForm.addEventListener('submit', async(e)=>{

e.preventDefault()

const form = e.target

const data = {
email: form.email.value,
password: form.password.value
}

const res = await fetch('/login',{
method:'POST',
headers:{'Content-Type':'application/json'},
body: JSON.stringify(data)
})

if(res.ok){

showMessage('loginMessage','Login exitoso','success')

setTimeout(()=>{
window.location.reload()
},1000)

}else{

const error = await res.text()
showMessage('loginMessage', error,'error')

}

})

}


// REGISTER

const registerForm = document.getElementById('registerForm')

if(registerForm){

registerForm.addEventListener('submit', async(e)=>{

e.preventDefault()

const form = e.target

const data = {
email: form.email.value,
password: form.password.value
}

const res = await fetch('/register',{
method:'POST',
headers:{'Content-Type':'application/json'},
body: JSON.stringify(data)
})

if(res.ok){

showMessage('registerMessage','Usuario registrado','success')

}else{

const error = await res.text()
showMessage('registerMessage', error,'error')

}

})

}

</script>

</body>
</html>